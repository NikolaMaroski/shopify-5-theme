{%- comment -%}
  MAIN SEARCH SECTION
  ===================
  Displays search results with filtering.
  
  INTERVIEW POINTS:
  - search object access
  - search.results types (product, article, page)
  - Pagination with search results
{%- endcomment -%}

{%- paginate search.results by 12 -%}
<section class="search-page">
  <div class="container">
    <div class="search-page__header">
      <h1 class="search-page__title">
        {%- if search.performed -%}
          {{ 'general.search.results_count' | t: count: search.results_count }}
          for "{{ search.terms }}"
        {%- else -%}
          Search
        {%- endif -%}
      </h1>

      <form action="{{ routes.search_url }}" method="get" class="search-page__form">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'general.search.placeholder' | t }}"
          class="search-page__input"
          aria-label="Search"
        >
        <button type="submit" class="btn btn--primary search-page__submit">
          {{ 'general.search.submit' | t }}
        </button>
      </form>
    </div>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="search-results">
          <div class="grid grid--4">
            {%- for item in search.results -%}
              {%- case item.object_type -%}
                {%- when 'product' -%}
                  {% render 'product-card', product: item, index: forloop.index %}
                
                {%- when 'article' -%}
                  <article class="search-result search-result--article">
                    {%- if item.image -%}
                      <a href="{{ item.url }}" class="search-result__image-wrapper">
                        <img
                          src="{{ item.image | image_url: width: 600 }}"
                          alt="{{ item.title | escape }}"
                          width="300"
                          height="200"
                          loading="lazy"
                          class="search-result__image"
                        >
                      </a>
                    {%- endif -%}
                    <div class="search-result__content">
                      <span class="search-result__type">Article</span>
                      <h3 class="search-result__title">
                        <a href="{{ item.url }}">{{ item.title }}</a>
                      </h3>
                      <p class="search-result__excerpt">{{ item.excerpt | strip_html | truncate: 120 }}</p>
                    </div>
                  </article>

                {%- when 'page' -%}
                  <article class="search-result search-result--page">
                    <div class="search-result__content">
                      <span class="search-result__type">Page</span>
                      <h3 class="search-result__title">
                        <a href="{{ item.url }}">{{ item.title }}</a>
                      </h3>
                      <p class="search-result__excerpt">{{ item.content | strip_html | truncate: 120 }}</p>
                    </div>
                  </article>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="Search pagination">
              <ul class="pagination__list">
                {%- if paginate.previous -%}
                  <li>
                    <a href="{{ paginate.previous.url }}" class="pagination__link pagination__link--prev">
                      &larr; {{ 'collections.pagination.previous' | t }}
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  {%- if part.is_link -%}
                    <li>
                      <a href="{{ part.url }}" class="pagination__link">{{ part.title }}</a>
                    </li>
                  {%- elsif part.title == paginate.current_page -%}
                    <li>
                      <span class="pagination__link pagination__link--current" aria-current="page">
                        {{ part.title }}
                      </span>
                    </li>
                  {%- else -%}
                    <li>
                      <span class="pagination__ellipsis">{{ part.title }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" class="pagination__link pagination__link--next">
                      {{ 'collections.pagination.next' | t }} &rarr;
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        </div>

      {%- else -%}
        <div class="search-page__empty">
          <p>{{ 'general.search.no_results' | t: terms: search.terms }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
            Browse all products
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}

<style>
  .search-page {
    padding: var(--space-2xl) 0;
    min-height: 60vh;
  }

  .search-page__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .search-page__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: 500;
    margin: 0 0 var(--space-lg);
  }

  .search-page__form {
    display: flex;
    gap: var(--space-sm);
    max-width: 500px;
    margin: 0 auto;
  }

  .search-page__input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid rgb(var(--color-contrast) / 0.2);
    border-radius: var(--radius-sm);
    font-family: inherit;
    font-size: var(--font-size-base);
  }

  .search-page__input:focus {
    outline: none;
    border-color: rgb(var(--color-accent));
  }

  .search-result {
    background: rgb(var(--color-contrast) / 0.02);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .search-result__image-wrapper {
    display: block;
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .search-result__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-result__content {
    padding: var(--space-md);
  }

  .search-result__type {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgb(var(--color-accent));
  }

  .search-result__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-weight: 500;
    margin: var(--space-xs) 0;
  }

  .search-result__title a {
    color: inherit;
    text-decoration: none;
  }

  .search-result__title a:hover {
    color: rgb(var(--color-accent));
  }

  .search-result__excerpt {
    font-size: var(--font-size-sm);
    color: rgb(var(--color-contrast) / 0.7);
    margin: 0;
  }

  .search-page__empty {
    text-align: center;
    padding: var(--space-2xl) 0;
  }

  .search-page__empty p {
    margin-bottom: var(--space-lg);
    color: rgb(var(--color-contrast) / 0.7);
  }

  @media (max-width: 600px) {
    .search-page__form {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Search results",
  "settings": []
}
{% endschema %}
