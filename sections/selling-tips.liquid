{%- comment -%}
  SELLING TIPS / VALUE PROPOSITION SECTION
  =========================================
  Up to 6 merchant-authored blocks, each with an icon, title, description,
  and an optional CTA link. Fully editable in the theme editor.

  Differentiator: Unlike static hard-coded "Why buy from us" blocks in most
  themes, every block is independently configurable — icon, copy, and link.
  Layout columns are also merchant-controlled.
{%- endcomment -%}

<section class="section selling-tips{% if section.settings.bg_tinted %} selling-tips--tinted{% endif %}">
  <div class="container">
    {%- if section.settings.subheading != blank or section.settings.heading != blank -%}
      <header class="selling-tips__header">
        {%- if section.settings.subheading != blank -%}
          <span class="selling-tips__subheading">{{ section.settings.subheading | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="selling-tips__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="selling-tips__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tip' -%}
            <div
              class="selling-tip{% if section.settings.center_content %} selling-tip--center{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.icon != 'none' -%}
                <div class="selling-tip__icon">
                  {%- case block.settings.icon -%}
                    {%- when 'heart' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                      </svg>
                    {%- when 'award' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
                      </svg>
                    {%- when 'zap' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                      </svg>
                    {%- when 'package' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                      </svg>
                    {%- when 'smile' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>
                      </svg>
                    {%- when 'globe' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                      </svg>
                    {%- when 'tag' -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
                      </svg>
                    {%- else -%}
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                      </svg>
                  {%- endcase -%}
                </div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3 class="selling-tip__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p class="selling-tip__text">{{ block.settings.text | escape }}</p>
              {%- endif -%}

              {%- if block.settings.link_label != blank and block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="selling-tip__link">
                  {{ block.settings.link_label | escape }}
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .selling-tips--tinted {
    background-color: rgba(var(--color-contrast), 0.03);
  }
</style>

{% schema %}
{
  "name": "Selling tips",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why choose us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for people who care"
    },
    {
      "type": "checkbox",
      "id": "center_content",
      "label": "Center block content",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "bg_tinted",
      "label": "Tinted background",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "tip",
      "name": "Tip",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none",    "label": "None" },
            { "value": "heart",   "label": "Heart" },
            { "value": "award",   "label": "Award / Ribbon" },
            { "value": "zap",     "label": "Zap / Speed" },
            { "value": "package", "label": "Package" },
            { "value": "smile",   "label": "Smile / Satisfaction" },
            { "value": "globe",   "label": "Globe / Worldwide" },
            { "value": "tag",     "label": "Tag / Price" }
          ],
          "default": "heart"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Handpicked quality"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every product is personally tested and selected by our team before it reaches you."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link URL (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Selling tips",
      "blocks": [
        {
          "type": "tip",
          "settings": {
            "icon": "award",
            "title": "Curated quality",
            "text": "Every item is personally reviewed before it reaches our shelves."
          }
        },
        {
          "type": "tip",
          "settings": {
            "icon": "zap",
            "title": "Fast dispatch",
            "text": "Orders placed before 2 pm ship the same business day."
          }
        },
        {
          "type": "tip",
          "settings": {
            "icon": "smile",
            "title": "Happiness guarantee",
            "text": "Not satisfied? We'll make it right — no questions asked."
          }
        }
      ]
    }
  ]
}
{% endschema %}
