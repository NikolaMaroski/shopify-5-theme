{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image
-%}

<section class="section product-section" data-product-section>
  <div class="container">
    <div class="product__grid">

      {%- comment -%} ── Gallery — sticky column, full gallery thumbnails only on detail ── {%- endcomment -%}
      <div class="product__gallery" data-product-gallery>
        <div class="product__main-image-wrapper">
          <img
            src="{{ featured_image | image_url: width: 1200 }}"
            srcset="
              {{ featured_image | image_url: width: 600 }} 600w,
              {{ featured_image | image_url: width: 900 }} 900w,
              {{ featured_image | image_url: width: 1200 }} 1200w
            "
            sizes="(min-width: 1200px) 50vw, 100vw"
            alt="{{ featured_image.alt | escape | default: product.title }}"
            width="{{ featured_image.width }}"
            height="{{ featured_image.height }}"
            class="product__main-image"
            data-main-image
            id="product-main-image"
          >
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product__thumbnails" role="list">
            {%- for image in product.images -%}
              <button
                type="button"
                class="product__thumbnail{% if image == featured_image %} is-active{% endif %}"
                data-thumbnail
                data-image-url="{{ image | image_url: width: 1200 }}"
                data-image-srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w"
                data-image-alt="{{ image.alt | escape | default: product.title }}"
                aria-label="{{ 'products.product.media.load_image' | t: index: forloop.index }}"
                role="listitem"
              >
                <img
                  src="{{ image | image_url: width: 150 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="75"
                  height="75"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Product info column ── {%- endcomment -%}
      <div class="product__info">
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p class="product__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product__title">{{ product.title }}</h1>

        <div class="product__price" data-product-price>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <s class="product__price-compare">{{ current_variant.compare_at_price | money }}</s>
          {%- endif -%}
          <span
            class="product__price-current{% if current_variant.compare_at_price > current_variant.price %} product__price-current--sale{% endif %}"
            data-price
          >
            {{- current_variant.price | money -}}
          </span>
        </div>

        {%- comment -%} Inline stock indicator {%- endcomment -%}
        {%- render 'stock-indicator', product: product, variant: current_variant -%}

        {%- comment -%} ── Product Form ── {%- endcomment -%}
        {%- form 'product', product, class: 'product__form', id: 'product-form', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

          {%- unless product.has_only_default_variant -%}
            <div class="product__options">
              {%- for option in product.options_with_values -%}
                <div class="product__option">
                  <label class="product__option-label" id="option-label-{{ option.position }}">
                    {{ option.name }}
                  </label>
                  <div
                    class="product__option-values"
                    data-option-position="{{ option.position }}"
                    role="group"
                    aria-labelledby="option-label-{{ option.position }}"
                  >
                    {%- for value in option.values -%}
                      {%- liquid
                        assign option_disabled = true
                        for variant in product.variants
                          case option.position
                            when 1
                              if variant.option1 == value and variant.available
                                assign option_disabled = false
                              endif
                            when 2
                              if variant.option2 == value and variant.available
                                assign option_disabled = false
                              endif
                            when 3
                              if variant.option3 == value and variant.available
                                assign option_disabled = false
                              endif
                          endcase
                        endfor
                      -%}
                      <button
                        type="button"
                        class="product__option-btn{% if current_variant.options[forloop.parentloop.index0] == value %} is-selected{% endif %}{% if option_disabled %} is-disabled{% endif %}"
                        data-option-btn
                        data-option-value="{{ value | escape }}"
                        data-option-position="{{ option.position }}"
                        {% if option_disabled %}disabled aria-disabled="true"{% endif %}
                        aria-pressed="{% if current_variant.options[forloop.parentloop.index0] == value %}true{% else %}false{% endif %}"
                      >
                        {{- value -}}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          {%- comment -%} Quantity stepper {%- endcomment -%}
          {%- if section.settings.show_quantity -%}
            <div class="product__quantity">
              <label class="product__quantity-label" for="product-quantity">
                {{- 'products.product.quantity.label' | t -}}
              </label>
              <div class="quantity-stepper">
                <button
                  type="button"
                  class="quantity-stepper__btn"
                  data-quantity-decrease
                  aria-label="{{ 'products.product.quantity.decrease' | t }}"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </button>
                <input
                  type="number"
                  id="product-quantity"
                  name="quantity"
                  value="1"
                  min="1"
                  class="quantity-stepper__input"
                  data-quantity-input
                  aria-label="{{ 'products.product.quantity.input_label' | t: product: product.title | escape }}"
                >
                <button
                  type="button"
                  class="quantity-stepper__btn"
                  data-quantity-increase
                  aria-label="{{ 'products.product.quantity.increase' | t }}"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </button>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%}
            Add to Cart button.
            No inline spinner — loading state is handled entirely by CSS (.is-loading class
            toggled by JS). This prevents the textContent + hidden-span conflict.
          {%- endcomment -%}
          <button
            type="submit"
            class="btn btn--primary btn--large btn--full product__add-btn"
            data-add-to-cart
            {% unless current_variant.available %}disabled{% endunless %}
          >
            <span data-add-to-cart-text>
              {%- if current_variant.available -%}
                {{- 'products.product.add_to_cart' | t -}}
              {%- else -%}
                {{- 'products.product.sold_out' | t -}}
              {%- endif -%}
            </span>
          </button>
        {%- endform -%}

        {%- comment -%} Description {%- endcomment -%}
        {%- if product.description != blank -%}
          <div class="product__description rte">
            {{ product.description }}
          </div>
        {%- endif -%}

        {%- comment -%} Meta — care, type, SKU {%- endcomment -%}
        <div class="product__meta">
          {%- if product.metafields.custom.care_instructions != blank -%}
            <details class="product__meta-item product__accordion">
              <summary class="product__accordion-trigger">
                {{- 'products.product.care_instructions' | t -}}
                <svg class="product__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <div class="product__accordion-body">{{ product.metafields.custom.care_instructions }}</div>
            </details>
          {%- endif -%}

          {%- if product.type != blank or current_variant.sku != blank -%}
            <details class="product__meta-item product__accordion">
              <summary class="product__accordion-trigger">
                {{- 'products.product.details' | t -}}
                <svg class="product__accordion-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <div class="product__accordion-body">
                <ul class="product__meta-list">
                  {%- if product.type != blank -%}
                    <li><strong>{{ 'products.product.type' | t }}:</strong> {{ product.type }}</li>
                  {%- endif -%}
                  {%- if current_variant.sku != blank -%}
                    <li><strong>{{ 'products.product.sku' | t }}:</strong> {{ current_variant.sku }}</li>
                  {%- endif -%}
                </ul>
              </div>
            </details>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%}
  Sticky Add to Cart bar — appears when the main ATC button scrolls off-screen.
  Only rendered when enabled via section settings.
{%- endcomment -%}
{%- if section.settings.enable_sticky_atc -%}
  <div
    class="sticky-atc"
    data-sticky-atc
    aria-hidden="true"
    aria-label="{{ 'products.product.sticky_atc_label' | t: title: product.title | escape }}"
  >
    <div class="container">
      <div class="sticky-atc__inner">
        <div class="sticky-atc__product">
          {%- if product.featured_image != blank -%}
            <img
              src="{{ product.featured_image | image_url: width: 80 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="40"
              height="40"
              class="sticky-atc__image"
            >
          {%- endif -%}
          <div class="sticky-atc__meta">
            <span class="sticky-atc__title">{{ product.title }}</span>
            <span class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</span>
          </div>
        </div>
        <button
          type="button"
          class="btn btn--primary sticky-atc__btn"
          data-sticky-atc-btn
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {%- if current_variant.available -%}
            {{- 'products.product.add_to_cart' | t -}}
          {%- else -%}
            {{- 'products.product.sold_out' | t -}}
          {%- endif -%}
        </button>
      </div>
    </div>
  </div>
{%- endif -%}

{%- comment -%} Variant data consumed by global.js ProductForm {%- endcomment -%}
<script type="application/json" id="product-json-{{ section.id }}">
  {
    "id": {{ product.id }},
    "title": {{ product.title | json }},
    "variants": {{ product.variants | json }},
    "options": {{ product.options | json }},
    "url": {{ product.url | json }},
    "featured_image": {{ product.featured_image | image_url: width: 1200 | json }}
  }
</script>

{%- comment -%} Structured data {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "image": [
    {%- for image in product.images limit: 3 -%}
      {{ image | image_url: width: 1200 | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "sku": {{ current_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ current_variant.price | divided_by: 100.0 }},
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
}
</script>

<style>
  /* ── Product grid layout ── */
  .product__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .product__gallery {
    position: sticky;
    top: calc(var(--header-height, 80px) + var(--space-lg));
  }

  .product__main-image-wrapper {
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: rgba(var(--color-contrast), 0.03);
  }

  .product__main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--duration-default) var(--ease-smooth);
  }

  /* ── Thumbnails ── */
  .product__thumbnails {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .product__thumbnail {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: none;
    padding: 0;
    transition: border-color var(--duration-short) var(--ease-smooth);
  }

  .product__thumbnail.is-active,
  .product__thumbnail:hover {
    border-color: rgb(var(--color-contrast));
  }

  .product__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Info column ── */
  .product__vendor {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(var(--color-contrast), 0.6);
    margin-bottom: var(--space-xs);
  }

  .product__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: 500;
    margin: 0 0 var(--space-md);
  }

  .product__price {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .product__price-compare {
    text-decoration: line-through;
    color: rgba(var(--color-contrast), 0.5);
    font-size: var(--font-size-lg);
  }

  .product__price-current--sale {
    color: rgb(var(--color-accent));
  }

  /* ── Form ── */
  .product__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .product__options {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .product__option-label {
    display: block;
    font-weight: 500;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .product__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .product__option-btn {
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid rgba(var(--color-contrast), 0.25);
    border-radius: var(--radius-sm);
    background: transparent;
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-family: var(--font-body);
    transition: all var(--duration-short) var(--ease-smooth);
    line-height: 1;
  }

  .product__option-btn:hover:not(.is-disabled) {
    border-color: rgb(var(--color-contrast));
  }

  .product__option-btn.is-selected {
    background: rgb(var(--color-contrast));
    color: rgb(var(--color-base));
    border-color: rgb(var(--color-contrast));
  }

  .product__option-btn.is-disabled {
    opacity: 0.35;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* ── Quantity stepper ── */
  .product__quantity {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .product__quantity-label {
    font-weight: 500;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .quantity-stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(var(--color-contrast), 0.25);
    border-radius: var(--radius-sm);
    overflow: hidden;
    width: fit-content;
  }

  .quantity-stepper__btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(var(--color-contrast), 0.7);
    transition: background var(--duration-short) var(--ease-smooth);
    flex-shrink: 0;
  }

  .quantity-stepper__btn:hover {
    background: rgba(var(--color-contrast), 0.06);
    color: rgb(var(--color-contrast));
  }

  .quantity-stepper__input {
    width: 52px;
    height: 44px;
    border: none;
    border-left: 1px solid rgba(var(--color-contrast), 0.2);
    border-right: 1px solid rgba(var(--color-contrast), 0.2);
    text-align: center;
    font-size: 1rem;
    font-family: var(--font-body);
    background: transparent;
    color: rgb(var(--color-contrast));
    -moz-appearance: textfield;
  }

  .quantity-stepper__input::-webkit-outer-spin-button,
  .quantity-stepper__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  /* ── ATC button loading state ── */
  .product__add-btn {
    position: relative;
    min-height: 52px;
  }

  .product__add-btn.is-loading {
    pointer-events: none;
  }

  .product__add-btn.is-loading [data-add-to-cart-text]::after {
    content: '';
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin-left: var(--space-sm);
    vertical-align: middle;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Description ── */
  .product__description {
    line-height: 1.8;
    color: rgba(var(--color-contrast), 0.85);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(var(--color-contrast), 0.1);
  }

  .product__description h2,
  .product__description h3 {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .product__description p {
    margin-bottom: var(--space-md);
  }

  .product__description ul,
  .product__description ol {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
  }

  /* ── Accordion meta ── */
  .product__meta {
    margin-top: var(--space-lg);
  }

  .product__accordion {
    border-bottom: 1px solid rgba(var(--color-contrast), 0.1);
  }

  .product__accordion-trigger {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: var(--space-md) 0;
    font-weight: 500;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .product__accordion-trigger::-webkit-details-marker {
    display: none;
  }

  .product__accordion-icon {
    transition: transform var(--duration-short) var(--ease-smooth);
    flex-shrink: 0;
  }

  .product__accordion[open] .product__accordion-icon {
    transform: rotate(180deg);
  }

  .product__accordion-body {
    padding-bottom: var(--space-md);
    font-size: var(--font-size-sm);
    color: rgba(var(--color-contrast), 0.75);
    line-height: 1.7;
  }

  .product__meta-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .product__meta-list li {
    margin-bottom: var(--space-xs);
  }

  /* ── Sticky ATC ── */
  .sticky-atc {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 150;
    background: rgb(var(--color-base));
    border-top: 1px solid rgba(var(--color-contrast), 0.12);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(100%);
    transition: transform var(--duration-default) var(--ease-smooth);
    will-change: transform;
  }

  .sticky-atc.is-visible {
    transform: translateY(0);
  }

  .sticky-atc__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
  }

  .sticky-atc__product {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    min-width: 0;
  }

  .sticky-atc__image {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .sticky-atc__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .sticky-atc__title {
    font-weight: 500;
    font-size: var(--font-size-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-atc__price {
    font-size: var(--font-size-sm);
    color: rgba(var(--color-contrast), 0.7);
  }

  .sticky-atc__btn {
    flex-shrink: 0;
    min-width: 160px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .product__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .product__gallery {
      position: static;
    }

    .sticky-atc__meta {
      display: none;
    }

    .sticky-atc__btn {
      min-width: 0;
      flex: 1;
    }
  }
</style>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_atc",
      "label": "Enable sticky Add to Cart bar",
      "default": true,
      "info": "A bar slides up from the bottom when the main button scrolls out of view."
    }
  ],
  "presets": [
    {
      "name": "Product"
    }
  ]
}
{% endschema %}
