{%- comment -%}
  RECENTLY VIEWED PRODUCTS
  ========================
  Fully client-side — reads from localStorage written by global.js RecentlyViewed.
  No Liquid loop, no server round-trip. Products are fetched via the Product JSON
  endpoint (/products/<handle>.js) and rendered with the same card markup pattern.

  Place on product.json template to show "You may also like" context.

  Differentiator: No app required, no cookie banner risk, renders only what the
  current visitor has actually seen on this device.
{%- endcomment -%}

{%- if section.settings.enable -%}
  <section
    class="section recently-viewed"
    data-recently-viewed
    data-max="{{ section.settings.max_products }}"
    data-current-id="{{ product.id | default: 0 }}"
    aria-label="{{ 'sections.recently_viewed.title' | t }}"
  >
    <div class="container">
      <header class="recently-viewed__header">
        <h2 class="recently-viewed__title">{{ section.settings.heading | escape | default: 'Recently Viewed' }}</h2>
      </header>

      {%- comment -%} Grid populated entirely by JS {%- endcomment -%}
      <div class="recently-viewed__grid" data-recently-viewed-grid></div>

      <p class="recently-viewed__empty" data-recently-viewed-empty hidden>
        {{- 'sections.recently_viewed.empty' | t -}}
      </p>
    </div>
  </section>

  <script>
    (function () {
      const section    = document.querySelector('[data-recently-viewed]');
      if (!section) return;

      const grid       = section.querySelector('[data-recently-viewed-grid]');
      const emptyMsg   = section.querySelector('[data-recently-viewed-empty]');
      const maxItems   = parseInt(section.dataset.max, 10) || 4;
      const currentId  = parseInt(section.dataset.currentId, 10) || 0;

      const handles = window.FiveTheme?.RecentlyViewed.getHandles(currentId).slice(0, maxItems);
      if (!handles || handles.length === 0) {
        section.hidden = true;
        return;
      }

      const cardHTML = (p) => {
        const price        = p.price_min;
        const comparePrice = p.compare_at_price_min;
        const onSale       = comparePrice > price;
        const savings      = onSale
          ? Math.round((comparePrice - price) * 100 / comparePrice)
          : 0;
        const img = p.featured_image
          ? `<img src="${p.featured_image}" alt="${p.title}" loading="lazy" class="product-card__image">`
          : '';
        const badge = !p.available
          ? `<span class="product-card__badge product-card__badge--sold-out">{{ 'products.product.sold_out' | t }}</span>`
          : onSale
            ? `<span class="product-card__badge product-card__badge--sale">-${savings}%</span>`
            : '';

        const priceHtml = onSale
          ? `<s class="product-card__price-compare">${window.FiveTheme.formatMoney(comparePrice)}</s>
             <span class="product-card__price-current product-card__price-current--sale">${window.FiveTheme.formatMoney(price)}</span>`
          : `<span class="product-card__price-current">${window.FiveTheme.formatMoney(price)}</span>`;

        return `
          <article class="product-card" data-product-card>
            <div class="product-card__media">
              <a href="/products/${p.handle}" class="product-card__image-link" tabindex="-1" aria-hidden="true">${img}</a>
              <div class="product-card__badges" aria-hidden="true">${badge}</div>
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">
                <a href="/products/${p.handle}" class="product-card__title-link">${p.title}</a>
              </h3>
              <div class="product-card__price">${priceHtml}</div>
            </div>
          </article>
        `;
      };

      Promise.all(
        handles.map(h =>
          fetch(`/products/${h}.js`)
            .then(r => r.ok ? r.json() : null)
            .catch(() => null)
        )
      ).then(products => {
        const valid = products.filter(Boolean);
        if (valid.length === 0) {
          section.hidden = true;
          return;
        }
        grid.innerHTML = valid.map(cardHTML).join('');
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Recently viewed",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Show recently viewed products",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently viewed"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
