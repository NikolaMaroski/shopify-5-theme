<div class="cart-drawer__overlay" data-cart-overlay></div>

<aside class="cart-drawer" data-cart-drawer aria-label="{{ 'sections.cart.title' | t }}" role="dialog" aria-modal="true">
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">{{ 'sections.cart.title' | t }}</h2>
    <button class="cart-drawer__close" data-cart-close aria-label="{{ 'accessibility.close' | t }}">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  {%- comment -%}
    All three containers are ALWAYS rendered so JS can always query them.
    show/hide is handled via inline style set by Liquid on first paint,
    then managed by JS after cart interactions.
  {%- endcomment -%}

  <div class="cart-drawer__body">
    {%- comment -%} Items list — visible when cart has products {%- endcomment -%}
    <div class="cart-drawer__items" data-cart-items{% if cart.item_count == 0 %} style="display:none"{% endif %}>
      {%- for item in cart.items -%}
        <div class="cart-item" data-cart-item data-key="{{ item.key }}">
          <div class="cart-item__image">
            {%- if item.image != blank -%}
              <img
                src="{{ item.image | image_url: width: 160 }}"
                alt="{{ item.title | escape }}"
                width="80"
                height="80"
                loading="lazy"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="cart-item__content">
            <p class="cart-item__title">{{ item.product.title }}</p>
            {%- if item.variant.title != 'Default Title' -%}
              <p class="cart-item__variant">{{ item.variant.title }}</p>
            {%- endif -%}
            <p class="cart-item__price">{{ item.final_line_price | money }}</p>
            <div class="cart-item__quantity">
              <button class="cart-item__quantity-btn" data-quantity-minus aria-label="{{ 'products.product.quantity.decrease' | t }}">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
              <input type="number" value="{{ item.quantity }}" min="0" class="cart-item__quantity-input" readonly>
              <button class="cart-item__quantity-btn" data-quantity-plus aria-label="{{ 'products.product.quantity.increase' | t }}">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
            </div>
          </div>
          <button class="cart-item__remove" data-remove-item aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Empty state — visible when cart is empty {%- endcomment -%}
    <div class="cart-drawer__empty" data-cart-empty{% if cart.item_count > 0 %} style="display:none"{% endif %}>
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <circle cx="9" cy="21" r="1"></circle>
        <circle cx="20" cy="21" r="1"></circle>
        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
      </svg>
      <p class="cart-drawer__empty-text">{{ 'sections.cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">
        {{ 'general.continue_shopping' | t }}
      </a>
    </div>
  </div>

  {%- comment -%} Footer — always rendered, hidden when empty {%- endcomment -%}
  <div class="cart-drawer__footer" data-cart-footer{% if cart.item_count == 0 %} style="display:none"{% endif %}>
    {%- if section.settings.show_cart_note -%}
      <div class="cart-drawer__note">
        <label for="cart-note" class="cart-drawer__note-label">{{ 'sections.cart.note' | t }}</label>
        <textarea
          id="cart-note"
          name="note"
          class="form-textarea cart-drawer__note-input"
          placeholder="{{ 'sections.cart.note_placeholder' | t }}"
          data-cart-note
        >{{ cart.note }}</textarea>
      </div>
    {%- endif -%}

    <div class="cart-drawer__subtotal">
      <span>{{ 'sections.cart.subtotal' | t }}</span>
      <span data-cart-subtotal>{{ cart.total_price | money }}</span>
    </div>
    <p class="cart-drawer__tax-note">{{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t }}</p>

    <div class="cart-drawer__actions">
      <a href="{{ routes.cart_url }}" class="btn btn--secondary btn--full">
        {{ 'sections.cart.view_cart' | t }}
      </a>
      <button type="submit" name="checkout" class="btn btn--primary btn--full" form="cart-drawer-form">
        {{ 'sections.cart.checkout' | t }}
      </button>
    </div>
  </div>

  <form id="cart-drawer-form" action="{{ routes.cart_url }}" method="post" style="display:none">
    <input type="hidden" name="checkout" value="1">
  </form>
</aside>

<style>
  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-lg);
  }

  .cart-drawer__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: var(--space-md);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid rgba(var(--color-contrast), 0.1);
  }

  .cart-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .cart-item__image img {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
  }

  .cart-item__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cart-item__title {
    font-weight: 500;
    font-size: var(--font-size-sm);
    line-height: 1.3;
    margin: 0;
  }

  .cart-item__variant {
    font-size: var(--font-size-sm);
    color: rgba(var(--color-contrast), 0.6);
    margin: 0;
  }

  .cart-item__price {
    font-size: var(--font-size-sm);
    font-weight: 500;
    margin: 0;
  }

  .cart-item__quantity {
    display: inline-flex;
    align-items: center;
    gap: 0;
    border: 1px solid rgba(var(--color-contrast), 0.2);
    border-radius: var(--radius-sm);
    overflow: hidden;
    margin-top: auto;
    width: fit-content;
  }

  .cart-item__quantity-btn {
    background: none;
    border: none;
    cursor: pointer;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-contrast), 0.7);
    transition: background var(--duration-short);
  }

  .cart-item__quantity-btn:hover {
    background: rgba(var(--color-contrast), 0.06);
    color: rgb(var(--color-contrast));
  }

  .cart-item__quantity-input {
    width: 32px;
    height: 28px;
    border: none;
    border-left: 1px solid rgba(var(--color-contrast), 0.2);
    border-right: 1px solid rgba(var(--color-contrast), 0.2);
    text-align: center;
    font-size: var(--font-size-sm);
    background: transparent;
    color: rgb(var(--color-contrast));
    -moz-appearance: textfield;
  }

  .cart-item__quantity-input::-webkit-outer-spin-button,
  .cart-item__quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
  }

  .cart-item__remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
    color: rgba(var(--color-contrast), 0.4);
    transition: color var(--duration-short);
    align-self: start;
    line-height: 0;
  }

  .cart-item__remove:hover {
    color: #ef4444;
  }

  .cart-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-3xl) var(--space-lg);
    gap: var(--space-lg);
    color: rgba(var(--color-contrast), 0.4);
  }

  .cart-drawer__empty-text {
    font-size: var(--font-size-lg);
    color: rgba(var(--color-contrast), 0.6);
    margin: 0;
  }

  .cart-drawer__footer {
    padding: var(--space-lg);
    border-top: 1px solid rgba(var(--color-contrast), 0.1);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cart-drawer__note-label {
    display: block;
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-xs);
    font-weight: 500;
  }

  .cart-drawer__note-input {
    min-height: 60px;
    resize: none;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    font-size: var(--font-size-lg);
    font-weight: 600;
  }

  .cart-drawer__tax-note {
    font-size: var(--font-size-sm);
    color: rgba(var(--color-contrast), 0.5);
    text-align: center;
    margin: 0;
  }

  .cart-drawer__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
</style>

{% schema %}
{
  "name": "Cart drawer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_cart_note",
      "label": "Show cart note",
      "default": false
    }
  ]
}
{% endschema %}
