{%- comment -%}
  FEATURED PRODUCTS SECTION
  =========================
  Displays products from a selected collection in a grid.
  
  INTERVIEW POINTS:
  - Collection object and product iteration
  - Liquid `limit` filter for controlling output
  - Section blocks for reordering/adding products
  - Lazy loading images for performance
  - Integration with product-card snippet
{%- endcomment -%}

<section class="section featured-products">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="featured-products__header">
        {%- if section.settings.subheading != blank -%}
          <span class="featured-products__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="featured-products__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- liquid
      assign collection = section.settings.collection
      assign products_to_show = section.settings.products_count
      assign columns = section.settings.columns
    -%}

    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="grid grid--{{ columns }}">
        {%- for product in collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product, index: forloop.index -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_view_all -%}
        <div class="featured-products__footer">
          <a href="{{ collection.url }}" class="btn btn--secondary">
            {{ section.settings.view_all_text | default: 'View all' }}
          </a>
        </div>
      {%- endif -%}

    {%- else -%}
      {%- comment -%} Placeholder content when no collection selected {%- endcomment -%}
      <div class="grid grid--{{ columns }}">
        {%- for i in (1..products_to_show) -%}
          <article class="product-card product-card--placeholder">
            <div class="product-card__image-wrapper">
              {{ 'product-1' | placeholder_svg_tag: 'product-card__image placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Product Title</h3>
              <p class="product-card__price">$0.00</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .featured-products__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .featured-products__subheading {
    display: block;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(var(--color-accent));
    margin-bottom: var(--space-sm);
  }

  .featured-products__heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: 500;
    margin: 0;
  }

  .featured-products__footer {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  .product-card--placeholder .placeholder-svg {
    width: 100%;
    height: auto;
    background: rgba(var(--color-contrast), 0.05);
  }
</style>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated Selection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 5,
      "label": "Products to show"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "5"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "View All Products"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
