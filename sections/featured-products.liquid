<section class="section featured-products">
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <header class="featured-products__header">
        {%- if section.settings.subheading != blank -%}
          <span class="featured-products__subheading">{{ section.settings.subheading }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="featured-products__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- liquid
      assign columns = section.settings.columns
      assign products_to_show = section.settings.products_count
      assign use_manual = false
      if section.blocks.size > 0
        assign use_manual = true
      endif
    -%}

    {%- if use_manual -%}
      {%- comment -%}
        Manual mode: products are picked one-by-one via blocks in the theme editor.
        Add up to 5 "Product" blocks and choose a product for each.
      {%- endcomment -%}
      <div class="grid grid--{{ columns }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' and block.settings.product != blank -%}
            <div {{ block.shopify_attributes }}>
              {%- render 'product-card', product: block.settings.product, index: forloop.index -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    {%- elsif section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
      {%- comment -%}
        Collection mode: pull the first N products from a selected collection.
      {%- endcomment -%}
      <div class="grid grid--{{ columns }}">
        {%- for product in section.settings.collection.products limit: products_to_show -%}
          {%- render 'product-card', product: product, index: forloop.index -%}
        {%- endfor -%}
      </div>

    {%- else -%}
      {%- comment -%} Placeholder shown in the editor before anything is configured {%- endcomment -%}
      <div class="grid grid--{{ columns }}">
        {%- for i in (1..products_to_show) -%}
          <article class="product-card product-card--placeholder">
            <div class="product-card__image-wrapper">
              {{ 'product-1' | placeholder_svg_tag: 'product-card__image placeholder-svg' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Product Title</h3>
              <p class="product-card__price">$0.00</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_view_all and section.settings.collection != blank and use_manual == false -%}
      <div class="featured-products__footer">
        <a href="{{ section.settings.collection.url }}" class="btn btn--secondary">
          {{ section.settings.view_all_text | default: 'View All Products' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .featured-products__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .featured-products__subheading {
    display: block;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgb(var(--color-accent));
    margin-bottom: var(--space-sm);
  }

  .featured-products__heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: 500;
    margin: 0;
  }

  .featured-products__footer {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  .product-card--placeholder .placeholder-svg {
    width: 100%;
    height: auto;
    background: rgba(var(--color-contrast), 0.05);
  }
</style>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Curated Selection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "header",
      "content": "Product source"
    },
    {
      "type": "paragraph",
      "content": "Add 'Product' blocks below to hand-pick specific products. If no blocks are added, products are pulled from the collection chosen here."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection (fallback)"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 5,
      "label": "Products to show (collection mode)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "5"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all button text",
      "default": "View All Products"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 5,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
